{
  "name": "vip-car-api",
  "version": "2.1.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev:local": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "db:backup": "bash ./scripts/backup.sh",
    "db:restore": "bash ./scripts/restore.sh",
    "migrate:create": "migrate-mongo create",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watchAll",
    "dev:tunnel": "concurrently \"pnpm run dev:local\" \"ts-node scripts/tunnel.ts\"",
    "dev:lt": "concurrently \"pnpm run dev:local\" \"lt --port 3000\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/genai": "^1.50.1",
    "@ngrok/ngrok": "^1.7.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "migrate-mongo": "^14.0.7",
    "mongoose": "^9.1.6",
    "multer": "^2.1.1",
    "openai": "^6.34.0",
    "resend": "^6.12.4",
    "stripe": "^22.2.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.9",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "jest": "^30.3.0",
    "localtunnel": "^2.0.2",
    "mongodb-memory-server": "^11.0.1",
    "ngrok": "5.0.0-beta.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "@types/express-serve-static-core": "5.1.1",
    "@types/express": "5.0.6"
  }
}

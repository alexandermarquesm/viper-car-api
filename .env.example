# Analyze Provider (gemini, openai)
ANALYZE_PROVIDER=gemini

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=your_openai_api_key

# MongoDB Connection URI
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/database

# Server Port
PORT=3000

# Secure JWT Secret (min 32 characters)
JWT_SECRET=your_jwt_secret_here_min_32_characters

# Environment (development, production, test)
NODE_ENV=development

# CORS Allowed Origins (comma separated list of allowed URLs)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081,exp://localhost:8081
